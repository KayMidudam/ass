local function CollectMoneyNearTarget(targetObj)
    StatusText = "Collecting money"

    local maxCollectTime = 15
    local stallLimit = 3
    local startTime = tick()
    local stalledPasses = 0
    local lastCount = math.huge

    while Settings.Enabled and (tick() - startTime) < maxCollectTime do
        local moneyParts = FindMoneyNearTarget(targetObj)
        local currentCount = #moneyParts

        if currentCount == 0 then
            StatusText = "Waiting"
            return false
        end

        Log("Nearby cash detected: " .. currentCount)

        for _, money in ipairs(moneyParts) do
            if not Settings.Enabled then
                StatusText = "Waiting"
                return false
            end

            if money and money.Parent and money.Transparency < 1 then
                MoveToTarget(money)

                local pickupEvent = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("CZDPZUS")
                if pickupEvent then
                    pcall(function()
                        pickupEvent:FireServer(money)
                    end)
                end

                local waited = 0
                while money and money.Parent and waited < 0.8 do
                    task.wait(0.1)
                    waited += 0.1
                end
            end
        end

        task.wait(0.35)

        local remainingCount = #FindMoneyNearTarget(targetObj)
        if remainingCount == 0 then
            StatusText = "Waiting"
            return false
        end

        if remainingCount < lastCount then
            stalledPasses = 0
        else
            stalledPasses += 1
        end

        lastCount = remainingCount

        if stalledPasses >= stallLimit then
            Log("Collection stalled, moving on")
            StatusText = "Waiting"
            return remainingCount > 0
        end
    end

    Log("Collection timeout reached, moving on")
    StatusText = "Waiting"
    return #FindMoneyNearTarget(targetObj) > 0
end
