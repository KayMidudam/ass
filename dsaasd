local function TryPickupNearbyCash()
    if Settings.IsDead then
        return
    end

    local spawnedBreadFolder = Workspace:FindFirstChild("Filter") and Workspace.Filter:FindFirstChild("SpawnedBread")
    local pickupEvent = ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("CZDPZUS")
    if not spawnedBreadFolder or not pickupEvent then
        return
    end

    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        return
    end

    if PickupLock.Lock.Busy then
        return
    end

    local charPos = hrp.Position
    local closestPart = nil
    local closestDistance = math.huge

    for _, breadPart in ipairs(spawnedBreadFolder:GetChildren()) do
        if breadPart:IsA("BasePart") and breadPart.Parent and breadPart.Transparency < 1 then
            local distance = (charPos - breadPart.Position).Magnitude
            if distance <= Settings.PickupDistance and distance < closestDistance then
                closestDistance = distance
                closestPart = breadPart
            end
        end
    end

    if closestPart then
        PickupLock.Lock.Busy = true
        pcall(function()
            pickupEvent:FireServer(closestPart)
        end)
        task.wait(0.35)
        PickupLock.Lock.Busy = false
    end
end

local function StartAutoPickup()
    if AutoPickupRunning then
        return
    end

    AutoPickupRunning = true

    AutoPickupThread = task.spawn(function()
        while AutoPickupRunning do
            TryPickupNearbyCash()
            task.wait(0.12)
        end
    end)
end

local function StopAutoPickup()
    AutoPickupRunning = false
    PickupLock.Lock.Busy = false
end

